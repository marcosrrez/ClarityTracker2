# ===================================================================
# ClarityTracker 2 - Environment Variables Template
# ===================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ===================================================================

# ===================================================================
# NODE ENVIRONMENT
# ===================================================================
NODE_ENV=production
PORT=5000

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================
# Format: postgresql://username:password@host:port/database
# Example for local: postgresql://claritytracker:password@localhost:5432/claritytracker_prod
# Example for Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/claritytracker
DATABASE_URL=postgresql://user:password@host:port/database

# ===================================================================
# JWT AUTHENTICATION
# ===================================================================
# Generate a secure random string (32+ characters):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-string-here-minimum-32-characters
JWT_EXPIRES_IN=7d

# ===================================================================
# SECURITY & CORS
# ===================================================================
# Your frontend domain (for CORS)
# Example: https://claritytracker.com or https://your-app.vercel.app
CORS_ORIGIN=https://your-domain.com

# Trust proxy setting for rate limiting (leave as is for most deployments)
TRUST_PROXY=loopback

# ===================================================================
# LOGGING
# ===================================================================
# Options: error, warn, info, debug, trace
LOG_LEVEL=info

# ===================================================================
# AI SERVICES (Optional - for session intelligence features)
# ===================================================================
# OpenAI API Key (for GPT-4 analysis)
OPENAI_API_KEY=sk-proj-...

# Google AI API Key (for Gemini)
GOOGLE_AI_API_KEY=...

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Azure Speech Service (for transcription)
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=eastus

# ===================================================================
# FIREBASE CONFIGURATION (for authentication)
# ===================================================================
VITE_FIREBASE_API_KEY=...
VITE_FIREBASE_AUTH_DOMAIN=...
VITE_FIREBASE_PROJECT_ID=...
VITE_FIREBASE_STORAGE_BUCKET=...
VITE_FIREBASE_MESSAGING_SENDER_ID=...
VITE_FIREBASE_APP_ID=...

# ===================================================================
# EMAIL SERVICE (Optional - for notifications)
# ===================================================================
# If using Resend
RESEND_API_KEY=re_...

# Email configuration
EMAIL_FROM=noreply@your-domain.com

# ===================================================================
# REDIS (Optional - for job queues and caching)
# ===================================================================
# Format: redis://host:port or redis://user:pass@host:port
REDIS_URL=redis://localhost:6379

# ===================================================================
# FILE STORAGE (Optional)
# ===================================================================
# Directory for uploaded files
UPLOAD_DIR=/tmp/uploads

# ===================================================================
# RATE LIMITING
# ===================================================================
# Maximum requests per window
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Auth-specific rate limits
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000

# ===================================================================
# MONITORING & ERROR TRACKING (Optional but recommended)
# ===================================================================
# Sentry DSN for error tracking
SENTRY_DSN=https://...@sentry.io/...

# ===================================================================
# FEATURE FLAGS (Optional)
# ===================================================================
ENABLE_SESSION_RECORDING=true
ENABLE_AI_INSIGHTS=true
ENABLE_EMAIL_NOTIFICATIONS=true
